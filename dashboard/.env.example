# ===========================================================================
# Municipal 311 City Assistant — environment configuration
# Copy to backend/.env (or project root .env) and fill in as needed.
# The system runs fully in MOCK_MODE without any real credentials.
# ===========================================================================

# Core ----------------------------------------------------------------------
# When true, all vendor integrations are simulated. Set to false to attempt
# real API calls (requires the relevant keys below + final SDK wiring).
MOCK_MODE=true

# Public URL where this backend is reachable (used to build the Twilio
# media-stream wss:// URL). With ngrok this is your https ngrok domain.
PUBLIC_BASE_URL=http://localhost:7860

# AWS Bedrock Nova Sonic (speech-to-speech) --------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL_ID=amazon.nova-sonic-v1:0

# NVIDIA NIM (high-accuracy address ASR / verification) --------------------
NVIDIA_API_KEY=

# Cekura (automated voice testing / red-team) ------------------------------
CEKURA_API_KEY=
CEKURA_BASE_URL=https://api.cekura.ai

# Frontend (optional) -------------------------------------------------------
# Leave empty in dev; Vite proxies /api and /twilio to the backend.
# VITE_API_BASE=
